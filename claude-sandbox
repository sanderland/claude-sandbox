#!/bin/bash
#
# claude-sandbox - Run Claude Code in isolated Lima VMs
#
# Creates project VMs from a YAML template (default) or by cloning an existing VM.
#
# Usage:
#   claude-sandbox                       # Start Claude in current directory
#   claude-sandbox -d /path/to/dir       # Start Claude in specified directory
#   claude-sandbox -p 80:8080,9090       # Expose ports on the VM
#   claude-sandbox -- --resume           # Pass arguments to claude
#   claude-sandbox shell                 # Open a shell in the VM
#   claude-sandbox shell -d ~/project    # Open shell for specific project
#   claude-sandbox stop                  # Stop current project's VM
#   claude-sandbox stop -d ~/project     # Stop specific project's VM
#   claude-sandbox stop-all              # Stop all sandbox VMs
#   claude-sandbox status                # Show all sandbox VMs status
#   claude-sandbox delete                # Delete current project's VM
#   claude-sandbox prune                 # Delete all project VMs (keeps base)
#

set -e

# Configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SANDBOX_DIR="$HOME/.claude-sandbox"
HOOKS_SERVER="$SCRIPT_DIR/claude-hooks-server"
HOOKS_SERVER_SOCKET="$SANDBOX_DIR/claude-hooks.sock"
HOOKS_SERVER_PIDFILE="$SANDBOX_DIR/claude-hooks-server.pid"
HOOKS_SERVER_LOG="$SANDBOX_DIR/claude-hooks-server.log"

# Configurable via environment or flags
DEFAULT_BASE_VM="${CLAUDE_SANDBOX_BASE_VM:-}"
DEFAULT_TEMPLATE="${CLAUDE_SANDBOX_TEMPLATE:-template:default}"
DEFAULT_CLAUDE_SETTINGS_DIR="$SANDBOX_DIR/.claude"
PORT_FORWARDS=""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[claude-sandbox]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[claude-sandbox]${NC} $1"; }
log_error() { echo -e "${RED}[claude-sandbox]${NC} $1"; }

# Parse port mappings (e.g., "80:8080,9090,5642:1234") into Lima JSON format
# Format: hostPort:guestPort or just port for same on both
parse_port_forwards() {
    local ports="$1"
    local json="["
    local first=true

    IFS=',' read -ra PORT_ARRAY <<< "$ports"
    for mapping in "${PORT_ARRAY[@]}"; do
        local host_port guest_port
        if [[ "$mapping" == *":"* ]]; then
            host_port="${mapping%%:*}"
            guest_port="${mapping#*:}"
        else
            host_port="$mapping"
            guest_port="$mapping"
        fi

        # Validate ports are numbers
        if ! [[ "$host_port" =~ ^[0-9]+$ ]] || ! [[ "$guest_port" =~ ^[0-9]+$ ]]; then
            log_error "Invalid port mapping: $mapping"
            exit 1
        fi

        if [ "$first" = true ]; then
            first=false
        else
            json+=","
        fi
        json+="{\"guestPort\":$guest_port,\"hostPort\":$host_port}"
    done

    json+="]"
    echo "$json"
}

check_lima() {
    if ! command -v limactl &> /dev/null; then
        log_error "limactl not found. Please install Lima first: brew install lima"
        exit 1
    fi
}

# Claude-specific Lima settings (portForwards and provision scripts)
# These are applied via --set when creating VMs
CLAUDE_PORT_FORWARDS='[{"guestSocket":"/tmp/claude-hooks.sock","hostSocket":"{{.Home}}/.claude-sandbox/claude-hooks.sock","reverse":true}]'

read -r -d '' CLAUDE_PROVISION_USER << 'PROVISION_EOF' || true
#!/bin/bash
set -eux
STAMP="$HOME/.claude-sandbox-provisioned"
if [ -f "$STAMP" ]; then exit 0; fi

# Ensure ~/.local/bin is in PATH (for login shells via .profile)
if ! grep -q 'local/bin' ~/.profile 2>/dev/null; then
  echo 'export PATH="$HOME/.local/bin:$PATH"' >> ~/.profile
fi
export PATH="$HOME/.local/bin:$PATH"
if ! command -v claude &> /dev/null; then
  curl -fsSL https://claude.ai/install.sh | bash
fi

# Symlink shared Claude config files into the local ~/.claude directory.
# ~/.claude-shared is a virtiofs mount shared across VMs; ~/.claude is local.
# Only credentials, settings, hooks, and CLAUDE.md are shared — runtime state
# like .claude.json stays per-VM to avoid cross-VM write races (virtiofs flock
# doesn't provide mutual exclusion between VMs).
SHARED="$HOME/.claude-shared"
LOCAL="$HOME/.claude"
mkdir -p "$LOCAL"
# Always symlink credentials so first-time login writes through to the shared mount.
ln -sf "$SHARED/.credentials.json" "$LOCAL/.credentials.json"
# Only symlink other config if it exists on the shared mount.
for name in settings.json hooks CLAUDE.md; do
  if [ -e "$SHARED/$name" ]; then
    ln -sf "$SHARED/$name" "$LOCAL/$name"
  fi
done

# Seed ~/.claude.json (the global runtime state file, separate from ~/.claude/)
# so the onboarding wizard doesn't re-trigger. Merges into any existing content
# since the install script may have already created this file.
python3 -c "
import json, os
path = os.path.expanduser('~/.claude.json')
try:
    with open(path) as f: cfg = json.load(f)
except (FileNotFoundError, json.JSONDecodeError): cfg = {}
cfg.update({'hasCompletedOnboarding': True, 'theme': 'dark', 'installMethod': 'native', 'autoUpdates': False})
with open(path, 'w') as f: json.dump(cfg, f)
os.chmod(path, 0o600)
"

touch "$STAMP"
PROVISION_EOF

# Generate --set arguments for Claude settings
# Would be better to use templating for this, but `--set ".base ..."` is disallowed/broken (similar to https://github.com/lima-vm/lima/issues/3741), and https://github.com/lima-vm/lima/issues/3404 is open
claude_set_args() {
    local project_dir="$1"
    local extra_ports="$2"

    local user_script
    user_script=$(printf '%s' "$CLAUDE_PROVISION_USER" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')

    local provision="[{\"mode\":\"user\",\"script\":$user_script}]"
    local mounts="[{\"location\":\"$project_dir\",\"writable\":true},{\"location\":\"$CLAUDE_SETTINGS_DIR\",\"mountPoint\":\"/home/$USER.linux/.claude-shared\",\"writable\":true}]"
    local env='{"UV_PROJECT_ENVIRONMENT": ".venv-agent"}'

    echo "--set"
    echo ".portForwards += $CLAUDE_PORT_FORWARDS"
    if [ -n "$extra_ports" ]; then
        local ports_json
        ports_json=$(parse_port_forwards "$extra_ports")
        echo "--set"
        echo ".portForwards += $ports_json"
    fi
    echo "--set"
    echo ".provision += $provision"
    echo "--set"
    echo ".mounts += $mounts"
    echo "--set"
    echo ".env += $env"
}

# Get VM name for a project directory
get_vm_name() {
    local project_dir="$1"
    local dirname
    dirname=$(basename "$project_dir")
    # Handle root directory edge case
    if [ -z "$dirname" ] || [ "$dirname" = "/" ]; then
        dirname="root"
    fi
    # Sanitize: replace non-alphanumeric with dash, lowercase
    echo "claude-sandbox-$(echo "$dirname" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//')"
}

is_hooks_server_running() {
    [ -S "$HOOKS_SERVER_SOCKET" ] && return 0
    [ -f "$HOOKS_SERVER_PIDFILE" ] && kill -0 "$(cat "$HOOKS_SERVER_PIDFILE")" 2>/dev/null && return 0
    return 1
}

start_hooks_server() {
    if is_hooks_server_running; then
        return 0
    fi

    log_info "Starting hooks server..."
    nohup "$HOOKS_SERVER" --socket "$HOOKS_SERVER_SOCKET" > "$HOOKS_SERVER_LOG" 2>&1 &
    echo $! > "$HOOKS_SERVER_PIDFILE"
    sleep 1

    if ! is_hooks_server_running; then
        log_error "Failed to start hooks server. Check $HOOKS_SERVER_LOG"
        cat "$HOOKS_SERVER_LOG"
        exit 1
    fi
}

stop_hooks_server() {
    if [ -f "$HOOKS_SERVER_PIDFILE" ]; then
        local pid
        pid=$(cat "$HOOKS_SERVER_PIDFILE")
        kill "$pid" 2>/dev/null && log_info "Stopped hooks server"
        rm -f "$HOOKS_SERVER_PIDFILE"
    fi
    rm -f "$HOOKS_SERVER_SOCKET"
}

vm_exists() {
    local name="$1"
    limactl list --format '{{.Name}}' 2>/dev/null | grep -qxF "$name"
}

is_vm_running() {
    local name="$1"
    limactl list --format '{{.Name}} {{.Status}}' 2>/dev/null | grep -qxF "$name Running"
}

get_vm_status() {
    local name="$1"
    limactl list --format '{{.Name}} {{.Status}}' 2>/dev/null | awk -v name="$name" '$1 == name {print $2}'
}

is_vm_in_error() {
    local name="$1"
    local status
    status=$(get_vm_status "$name")
    [ "$status" = "Broken" ]
}

# Create a project VM by cloning an existing VM
create_vm_from_clone() {
    local vm_name="$1"
    local project_dir="$2"
    local base_vm="$3"
    local ports="$4"

    if ! vm_exists "$base_vm"; then
        log_error "Base VM '$base_vm' not found."
        log_error "Create it first, then try again."
        exit 1
    fi

    # Ensure base VM is stopped for cloning
    if is_vm_running "$base_vm"; then
        log_info "Stopping base VM for cloning..."
        limactl stop "$base_vm"
    fi

    log_info "Cloning '$base_vm' to '$vm_name'..."

    # Build set args array
    local -a set_args
    while IFS= read -r line; do
        set_args+=("$line")
    done < <(claude_set_args "$project_dir" "$ports")

    limactl clone "$base_vm" "$vm_name" "${set_args[@]}" -y

    log_info "Project VM '$vm_name' created from clone"
}

# Create a project VM from a YAML template
create_vm_from_template() {
    local vm_name="$1"
    local project_dir="$2"
    local template="$3"
    local ports="$4"

    log_info "Creating '$vm_name' from template..."
    log_warn "This may take a while on first run..."

    # Build set args array
    local -a set_args
    while IFS= read -r line; do
        set_args+=("$line")
    done < <(claude_set_args "$project_dir" "$ports")

    limactl start --name="$vm_name" "$template" "${set_args[@]}" -y

    log_info "Project VM '$vm_name' created from template"
}

# Create a project VM (decides between clone and template)
create_project_vm() {
    local vm_name="$1"
    local project_dir="$2"
    local ports="$3"

    # Clone takes precedence if specified, otherwise use template
    if [ -n "$BASE_VM" ]; then
        create_vm_from_clone "$vm_name" "$project_dir" "$BASE_VM" "$ports"
    else
        create_vm_from_template "$vm_name" "$project_dir" "$TEMPLATE" "$ports"
    fi
}

stop_vm() {
    local name="$1"
    local force="${2:-false}"
    if is_vm_running "$name" || [ "$force" = true ]; then
        log_info "Stopping VM '$name'..."
        if [ "$force" = true ]; then
            limactl stop -f "$name"
        else
            limactl stop "$name"
        fi
    fi
}

stop_all_vms() {
    local force="${1:-false}"
    log_info "Stopping all sandbox VMs..."
    for vm in $(limactl list --format '{{.Name}}' | grep '^claude-sandbox'); do
        if is_vm_running "$vm" || [ "$force" = true ]; then
            log_info "Stopping $vm..."
            if [ "$force" = true ]; then
                limactl stop -f "$vm"
            else
                limactl stop "$vm"
            fi
        fi
    done
    stop_hooks_server
    log_info "All stopped"
}

delete_vm() {
    local name="$1"
    if vm_exists "$name"; then
        log_info "Deleting VM '$name'..."
        limactl delete -f "$name"
    fi
}

prune_project_vms() {
    log_info "Deleting all project VMs..."
    local count=0
    for vm in $(limactl list --format '{{.Name}}' 2>/dev/null | grep '^claude-sandbox' || true); do
        if is_vm_running "$vm"; then
            log_info "Stopping $vm..."
            limactl stop "$vm"
        fi
        log_info "Deleting $vm..."
        limactl delete -f "$vm"
        ((count++)) || true
    done
    if [ $count -eq 0 ]; then
        log_info "No project VMs to delete"
    else
        log_info "Deleted $count project VM(s)"
    fi
}

show_status() {
    echo "=== Claude Sandbox Status ==="
    echo
    echo "Base VM: ${BASE_VM:-"(not set)"}"
    echo "Template: ${TEMPLATE:-"(not set)"}"
    echo
    echo -n "Hooks server: "
    if is_hooks_server_running; then
        echo "Running"
    else
        echo "Not running"
    fi
    echo
    echo "VMs:"
    local found=0
    for vm in $(limactl list --format '{{.Name}}' 2>/dev/null | grep '^claude-sandbox' || true); do
        found=1
        local status
        status=$(limactl list --format '{{.Name}} {{.Status}}' | awk -v name="$vm" '$1 == name {print $2}')
        echo "  $vm: $status"
    done
    if [ $found -eq 0 ]; then
        echo "  No sandbox VMs created yet"
    fi
}

show_help() {
    cat << 'EOF'
Usage: claude-sandbox [COMMAND] [OPTIONS] [-- CLAUDE_ARGS...]

Run Claude Code in an isolated Lima VM.
By default, creates VMs from Lima's default template with Claude settings.

Commands:
  (none)        Start Claude in the VM (default)
  shell         Open a shell in the VM instead of Claude
  stop          Stop the project's VM
  stop-all      Stop all sandbox VMs
  restart-hooks Restart the hooks server
  status        Show all sandbox VMs status
  delete        Delete the project's VM
  prune         Delete all project VMs

Options:
  -d, --dir DIR          Project directory (default: current directory)
  -s, --settings DIR     Claude settings directory (default: ~/.claude-sandbox/.claude)
  -c, --clone-from VM    Clone from an existing VM (or set CLAUDE_SANDBOX_BASE_VM)
  -t, --template YAML    Create from a YAML template (default: template:default)
  -p, --ports PORTS      Expose ports (e.g., 80:8080,9090,5642:1234)
                         Format: hostPort:guestPort or port for same on both
  -f, --force            Force stop VM (use with stop/stop-all)
  -h, --help             Show this help message

Environment variables:
  CLAUDE_SANDBOX_BASE_VM                   Default VM to clone from
  CLAUDE_SANDBOX_TEMPLATE                  Default template to use
  CLAUDE_SANDBOX_SETTINGS                  Claude settings directory

Examples:
  claude-sandbox                           # Uses Lima default template
  claude-sandbox -d ~/projects/myapp       # Start in specific dir
  claude-sandbox shell                     # Open shell in VM
  claude-sandbox -- --resume               # Pass args to claude
  claude-sandbox status                    # See all VMs
  claude-sandbox -p 8080,3000:3000         # Expose ports 8080 and 3000

  # Clone from an existing VM (e.g., one with dev tools pre-installed)
  claude-sandbox --clone-from my-dev-tools
  export CLAUDE_SANDBOX_BASE_VM=my-dev-tools  # Or set as default
EOF
}

main() {
    check_lima
    mkdir -p "$SANDBOX_DIR"

    # Parse arguments
    local project_dir=""
    local claude_args=()
    local parsing_claude_args=false
    local command=""
    local next_is_dir=false
    local next_is_settings=false
    local next_is_clone=false
    local next_is_template=false
    local next_is_ports=false
    local force_stop=false
    local settings_dir="${CLAUDE_SANDBOX_SETTINGS:-$DEFAULT_CLAUDE_SETTINGS_DIR}"
    BASE_VM="$DEFAULT_BASE_VM"
    TEMPLATE="$DEFAULT_TEMPLATE"

    for arg in "$@"; do
        if [ "$parsing_claude_args" = true ]; then
            claude_args+=("$arg")
        elif [ "$next_is_dir" = true ]; then
            if [ ! -d "$arg" ]; then
                log_error "Directory not found: $arg"
                exit 1
            fi
            project_dir="$(cd "$arg" && pwd)"
            next_is_dir=false
        elif [ "$next_is_settings" = true ]; then
            settings_dir="$arg"
            next_is_settings=false
        elif [ "$next_is_clone" = true ]; then
            BASE_VM="$arg"
            next_is_clone=false
        elif [ "$next_is_template" = true ]; then
            TEMPLATE="$arg"
            next_is_template=false
        elif [ "$next_is_ports" = true ]; then
            PORT_FORWARDS="$arg"
            next_is_ports=false
        elif [ "$arg" = "--" ]; then
            parsing_claude_args=true
        elif [ "$arg" = "-d" ] || [ "$arg" = "--dir" ]; then
            next_is_dir=true
        elif [ "$arg" = "-s" ] || [ "$arg" = "--settings" ]; then
            next_is_settings=true
        elif [ "$arg" = "-c" ] || [ "$arg" = "--clone-from" ]; then
            next_is_clone=true
        elif [ "$arg" = "-t" ] || [ "$arg" = "--template" ]; then
            next_is_template=true
        elif [ "$arg" = "-p" ] || [ "$arg" = "--ports" ]; then
            next_is_ports=true
        elif [ "$arg" = "-f" ] || [ "$arg" = "--force" ]; then
            force_stop=true
        elif [ -z "$command" ]; then
            case "$arg" in
                shell|stop|delete|status|stop-all|prune|restart-hooks|--help|-h)
                    command="$arg"
                    ;;
                *)
                    log_error "Unknown command: $arg"
                    log_error "Run 'claude-sandbox --help' for usage"
                    exit 1
                    ;;
            esac
        fi
    done

    # Default to current directory if not specified
    if [ -z "$project_dir" ]; then
        project_dir="$(pwd)"
    fi

    # Set Claude settings path
    CLAUDE_SETTINGS_DIR="$settings_dir"
    mkdir -p "$CLAUDE_SETTINGS_DIR"

    local vm_name
    vm_name=$(get_vm_name "$project_dir")

    case "$command" in
        stop)
            stop_vm "$vm_name" "$force_stop"
            log_info "Stopped"
            exit 0
            ;;
        stop-all)
            stop_all_vms "$force_stop"
            exit 0
            ;;
        restart-hooks)
            stop_hooks_server
            start_hooks_server
            log_info "Hooks server restarted"
            exit 0
            ;;
        status)
            show_status
            exit 0
            ;;
        delete)
            delete_vm "$vm_name"
            log_info "Deleted"
            exit 0
            ;;
        prune)
            prune_project_vms
            exit 0
            ;;
        --help|-h)
            show_help
            exit 0
            ;;
    esac

    start_hooks_server

    # Create or start project VM
    if ! vm_exists "$vm_name"; then
        create_project_vm "$vm_name" "$project_dir" "$PORT_FORWARDS"
        # Only start if created from clone (template starts automatically)
        if [ -n "$BASE_VM" ] && ! is_vm_running "$vm_name"; then
            if is_vm_in_error "$vm_name"; then
                log_warn "VM '$vm_name' is in error state, stopping before restart..."
                limactl stop "$vm_name" 2>/dev/null || true
            fi
            log_info "Starting VM '$vm_name'..."
            limactl start "$vm_name" -y
        fi
    else
        # VM exists
        if [ -n "$PORT_FORWARDS" ]; then
            if is_vm_running "$vm_name"; then
                log_error "Cannot add ports to running VM '$vm_name'"
                log_error "Stop the VM first: claude-sandbox stop"
                exit 1
            fi
            # Add ports to stopped VM
            local ports_json
            ports_json=$(parse_port_forwards "$PORT_FORWARDS")
            log_info "Adding port forwards: $PORT_FORWARDS"
            limactl edit "$vm_name" --set ".portForwards += $ports_json" -y
        fi

        if ! is_vm_running "$vm_name"; then
            # Handle VMs stuck in error state
            if is_vm_in_error "$vm_name"; then
                log_warn "VM '$vm_name' is in error state, stopping before restart..."
                limactl stop "$vm_name" 2>/dev/null || true
            fi
            log_info "Starting VM '$vm_name'..."
            limactl start "$vm_name" -y
        else
            log_info "VM '$vm_name' already running"
        fi
    fi

    log_info "Project: $project_dir"
    echo

    # Shell command: just open a bash shell
    if [ "$command" = "shell" ]; then
        exec limactl shell "$vm_name" bash -l -c "cd '$project_dir' && exec bash"
    fi

    # Build claude command with any extra arguments
    local claude_cmd="claude --dangerously-skip-permissions"
    if [ ${#claude_args[@]} -gt 0 ]; then
        for arg in "${claude_args[@]}"; do
            claude_cmd+=" $(printf '%q' "$arg")"
        done
    fi

    local lima_cmd="limactl shell \"$vm_name\" bash -l -c \"cd '$project_dir' && CLAUDE_SANDBOX_UUID=$(uuidgen) CLAUDE_HOOKS_SOCKET=/tmp/claude-hooks.sock $claude_cmd\""
    if [ -n "$TMUX" ]; then
	# Already in tmux, run claude directly
	local current_session
	current_session=$(tmux display-message -p '#S')
	if [[ ! "$current_session" =~ ^claude ]]; then
	    tmux rename-session "claude-sandbox-$current_session"
	fi
	exec tmux new-window "$lima_cmd"
    else
	# Not in tmux, start a new tmux session with claude
	exec tmux new-session -s "$vm_name-$$" "$lima_cmd"
    fi
}

main "$@"
